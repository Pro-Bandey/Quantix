{
  "manifest_version": 3,
  "name": "Quantix - Calculator & Unit Converter",
  "short_name": "Quantix",
  "version": "4.0",
  "description": "Quantix is a lightweight, responsive utility calculator and comprehensive unit converter.",
  "author": "Pro Bandey",
  "homepage_url": "https://Pro-Bandey.github.io/?rdm=Quantix",

  "offline_enabled": true,

  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "64": "icons/64.png",
    "128": "icons/128.png",
    "256": "icons/256.png"
  },

  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "64": "icons/64.png",
      "128": "icons/128.png",
      "256": "icons/256.png"
    }
  },

  "side_panel": {
    "default_path": "index.html",
    "default_title": "Quantix - Calculator & Unit Converter"
  },

  "permissions": ["sidePanel", "contextMenus"],

  "background": {
    "service_worker": "./background.js"
  }
}
